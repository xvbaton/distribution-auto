/* ═══════════════════════════════════════════════════════════
   SIDEBAR — DIMENSIONS
═══════════════════════════════════════════════════════════ */
.dims-list {
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.dim-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--c-border);
}
.dim-row:last-child { border-bottom: none; }
.dim-key {
  font-size: 0.78rem;
  color: var(--c-ink-4);
  font-weight: 500;
  flex-shrink: 0;
  max-width: 52%;
}
.dim-val {
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--c-ink-2);
  text-align: right;
  font-variant-numeric: tabular-nums;
  margin: 0;
}

