---
import Base from "../layouts/Base.astro";
import { getDB, getBrand, getModelsByBrand } from "../lib/db";
import AdBanner from "../components/AdBanner.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroOverlay from "../components/HeroOverlay.astro";

const { brand: brandSlug } = Astro.params;
const db = getDB();

const brand = await getBrand(db, brandSlug!);
if (!brand) return Astro.redirect("/");

const models = await getModelsByBrand(db, (brand as any).id);
const brandName = (brand as any).name;

// SEO Schema.org: CollectionPage & Breadcrumbs
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Accueil", item: Astro.site ? Astro.site.toString() : "https://distribution-auto.com" },
        { "@type": "ListItem", position: 2, name: brandName },
      ],
    },
    {
      "@type": "CollectionPage",
      name: `Modèles ${brandName} - Chaîne ou Courroie`,
      description: `Tous les modèles de ${brandName} et leurs spécifications techniques.`,
      url: Astro.url.href,
    },
  ],
};
---

<Base
  title={`Moteurs & Entretien ${brandName} — tous les modèles`}
  description={`Trouvez le type de distribution (chaîne ou courroie) de votre ${brandName}. ${models.length} modèles disponibles.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <Breadcrumb links={[
    { label: "Toutes les marques", url: "/" },
    { label: brandName }
  ]} />

  <header class="hero-brand">
    <HeroOverlay />
    <div class="wrap hero-content">
      <div class="brand-avatar-container">
        <img
          src={`/logos/optimized/${brandSlug}.png`}
          alt={`Logo ${brandName}`}
          class="brand-logo"
          loading="lazy"
          decoding="async"
          width="70"
          height="70"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="brand-avatar-fallback" style="display: none;">
          {brandName.charAt(0)}
        </div>
      </div>
      <div class="hero-text">
        <span class="eyebrow">Constructeur Automobile</span>
        <h1 class="title">Modèles <span class="accent">{brandName}</span></h1>
        <p class="subtitle">
          Sélectionnez un de nos <strong>{models.length} modèles</strong> pour accéder aux motorisations et périodicités d'entretien.
        </p>
      </div>
    </div>
  </header>

  <section class="wrap main-layout">
    <div class="premium-list-models">
      {
        models.map((model: any) => (
          <a
            href={`/${brandSlug}/${model.slug}`}
            class="model-list-card"
          >
            <div class="model-list-info">
              <h2 class="model-name">{model.name}</h2>
              <span class="model-action">Voir les motorisations disponibles</span>
            </div>
            <div class="model-list-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Section Publicité Bas de Page -->
  <div class="wrap ad-banner-bottom">
    <AdBanner type="horizontal" />
  </div>

</Base>

<style>
  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .ad-banner-bottom { margin: 2rem auto 6rem; }
  
  /* Hero Brand */
  .hero-brand {
    background: radial-gradient(circle at 80% -20%, #1e293b, #020617 80%);
    color: #fff; padding: 5rem 0; position: relative; overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .hero-content {
    display: flex; align-items: center; gap: 2.5rem; position: relative; z-index: 2;
  }
  .brand-avatar-container {
    width: 100px; height: 100px; border-radius: 24px; background: #fff;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 16px 40px rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1); overflow: hidden; flex-shrink: 0;
  }
  .brand-logo { width: 70px; height: 70px; object-fit: contain; }
  .brand-avatar-fallback {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    display: flex; align-items: center; justify-content: center;
    font-size: 3.5rem; font-weight: 900; color: #fff;
  }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    padding: 0.4rem 1.2rem; border-radius: var(--r-pill);
    font-size: 0.8rem; font-weight: 700; color: #93c5fd; margin-bottom: 1.5rem;
  }
  .title { font-size: clamp(3rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.1; margin: 0 0 1rem; letter-spacing: -0.03em; }
  .accent { color: #93c5fd; }
  .subtitle { font-size: 1.15rem; color: #94a3b8; margin: 0; line-height: 1.6; max-width: 650px; }

  /* Horizontal List layout for Models */
  .main-layout { margin-top: 3rem; margin-bottom: 4rem; }
  
  .premium-list-models {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  
  .model-list-card {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 1.5rem; background: var(--c-card); border-radius: var(--r-sm);
    border: 1px solid var(--c-border); box-shadow: var(--sh-card);
    text-decoration: none; transition: all 0.2s ease;
  }
  
  .model-list-info { display: flex; flex-direction: column; gap: 0.35rem; }
  .model-name { font-size: 1.2rem; font-weight: 800; color: var(--c-primary); margin: 0; letter-spacing: -0.01em; }
  .model-action { font-size: 0.85rem; color: var(--c-text-muted); font-weight: 500; }
  
  .model-list-icon { 
    color: var(--c-text-light); transition: transform 0.2s; 
    background: var(--c-bg-alt); width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .model-list-card:hover {
    border-color: #bfdbfe; box-shadow: var(--sh-card-hover); background: #f8fafc;
    transform: translateY(-2px);
  }
  .model-list-card:hover .model-list-icon {
    color: var(--c-accent); transform: translateX(4px); background: #eff6ff;
  }

  @media (max-width: 1024px) {
    .premium-list-models { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .premium-list-models { grid-template-columns: 1fr; gap: 0.75rem; }
    .model-list-card { padding: 1.25rem; }
    .hero-brand { padding: 4rem 0; text-align: center; }
    .hero-content { flex-direction: column; gap: 1.5rem; }
    .brand-avatar-container { width: 80px; height: 80px; }
    .brand-logo { width: 55px; height: 55px; }
    .brand-avatar-fallback { font-size: 2.5rem; }
  }
</style>
