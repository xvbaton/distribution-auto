---
import Base from '../layouts/Base.astro';
import { getDB, getBrands } from '../lib/db';

const db = getDB();
const brands = await getBrands(db);
---
<Base title="Chaîne ou courroie ? Tous les véhicules" description="Trouvez en 2 clics si votre voiture a une chaîne ou une courroie de distribution.">
  <section style="text-align:center; padding: 3rem 0 2rem;">
    <h1 style="font-size:2.2rem; margin-bottom:1rem;">Chaîne ou courroie ?</h1>
    <p style="font-size:1.1rem; color:#555; max-width:600px; margin:0 auto;">
      Vérifiez le type de distribution de votre véhicule et les intervalles d'entretien.
      Base de données de {brands.length} marques et plus de 2600 motorisations.
    </p>
  </section>
  <section>
    <h2 style="font-size:1.3rem; margin-bottom:1.5rem;">Toutes les marques</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); gap:0.75rem;">
      {brands.map((brand: any) => (
        <a href={`/distribution/${brand.slug}`} style="display:block; padding:1rem; background:white; border-radius:8px; border:1px solid #e0e0e0; text-decoration:none; color:#1a1a1a; font-weight:500; text-align:center;">
          {brand.name}
        </a>
      ))}
    </div>
  </section>
</Base>
