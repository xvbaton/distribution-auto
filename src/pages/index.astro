---
import Base from '../layouts/Base.astro';
import { getDB, getBrands } from '../lib/db';
import AdBanner from '../components/AdBanner.astro';
import HeroOverlay from '../components/HeroOverlay.astro';

const db = getDB();
const brands = await getBrands(db);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Distribution Auto",
  "url": Astro.site ? Astro.site.toString() : "https://distribution-auto.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://distribution-auto.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Base 
  title="Entretien Moteur : Chaîne ou courroie ?" 
  description="Trouvez le type de distribution de votre véhicule et de votre moteur en quelques clics."
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section class="hero-home">
    <HeroOverlay />
    <div class="wrap hero-content">
      <div class="hero-badge">Base de données moteurs 2026 <span>⚡</span></div>
      
      <h1>Distribution <span class="accent-text">Auto</span></h1>
      <p class="subtitle">
        Vérifiez instantanément la mécanique de votre véhicule. Recherchez par modèle (ex: <em>Golf 8</em>) ou par motorisation (ex: <em>1.5 dCi</em>, <em>THP</em>).
      </p>
      
      <!-- Premium Search Bar -->
      <div class="search-container">
        <label for="main-search" class="sr-only">Rechercher un modèle ou moteur</label>
        <div class="search-input-wrapper glass-panel">
          <span class="search-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </span>
          <input type="search" id="main-search" placeholder="Ex: Peugeot 308, Clio 1.5 dCi..." autocomplete="off">
          <div class="search-shortcut">⌘K</div>
        </div>
        <div id="search-results" class="search-results hidden glass-panel-dropdown" aria-live="polite"></div>
      </div>

      <div class="stats-row">
        <div class="stat-item">
          <strong>{brands.length}</strong> Marques
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <strong>+12k</strong> Moteurs
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <strong>Gratuit</strong> & Rapide
        </div>
      </div>
    </div>
  </section>

  <section class="brands-section wrap">
    <div class="section-header">
      <h2>Constructeurs Automobiles</h2>
      <p>Sélectionnez une marque pour explorer ses fiches techniques détaillées.</p>
    </div>
    
    <div class="premium-grid">
      {brands.map((brand: any) => (
        <a href={`/${brand.slug}`} class="brand-card square-card">
          <div class="brand-logo-circle">
             <img
              src={`/logos/car-logos-dataset/logos/optimized/${brand.slug}.png`}
              alt={`Logo ${brand.name}`}
              loading="lazy"
              decoding="async"
              width="50"
              height="50"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <span class="brand-letter-fallback" style="display:none">{brand.name.charAt(0)}</span>
          </div>
          <span class="brand-name">{brand.name}</span>
          <div class="card-hover-fx"></div>
        </a>
      ))}
    </div>
  </section>

  <!-- Section Publicité Bas de Page -->
  <div class="wrap ad-banner-bottom">
    <AdBanner type="horizontal" />
  </div>

</Base>

<script is:inline>
  function initSearch() {
    const searchInput = document.getElementById('main-search');
    const resultsDiv = document.getElementById('search-results');
    let debounceTimer;

    // Shortcut Cmd+K / Ctrl+K
    const handleKeydown = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchInput?.focus();
      }
    };
    document.removeEventListener('keydown', handleKeydown);
    document.addEventListener('keydown', handleKeydown);

    if (searchInput && resultsDiv) {
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        const q = e.target.value.trim();

        if (q.length < 2) {
          resultsDiv.innerHTML = '';
          resultsDiv.classList.add('hidden');
          return;
        }

        debounceTimer = setTimeout(async () => {
          try {
            const res = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
            const data = await res.json();

            if (data && data.length > 0) {
              resultsDiv.innerHTML = data.map((item) => `
                <a href="/${item.brand_slug}/${item.model_slug}" class="search-item">
                  <div class="search-item-info">
                    <span class="brand-tag">${item.brand_name}</span>
                    <span class="model-name">${item.model_name}</span>
                  </div>
                  <span class="search-arrow">→</span>
                </a>
              `).join('');
              resultsDiv.classList.remove('hidden');
            } else {
              resultsDiv.innerHTML = '<div class="no-results">Aucun résultat trouvé pour cette recherche.</div>';
              resultsDiv.classList.remove('hidden');
            }
          } catch (err) {
            console.error('Search error:', err);
          }
        }, 250);
      });

      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
          resultsDiv.classList.add('hidden');
        }
      });
    }
  }

  // Initialize immediately and on ViewTransitions astro:page-load
  initSearch();
  document.addEventListener('astro:page-load', initSearch);
</script>

<style is:global>
  :root {
    --c-bg: #f8fafc;
    --c-card: #ffffff;
    --c-primary: #0f172a;
    --c-primary-dark: #020617;
    --c-accent: #3b82f6;
    --c-accent-hover: #2563eb;
    --c-text: #334155;
    --c-text-muted: #64748b;
    --c-border: #e2e8f0;
    --c-border-light: #f1f5f9;
    --r-pill: 9999px;
    --r-base: 16px;
    --r-sm: 12px;
    --sh-glass: 0 12px 40px -8px rgba(0, 0, 0, 0.2);
    --sh-card: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -2px rgba(0,0,0,0.05);
    --sh-card-hover: 0 20px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.05);
    --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  body { background-color: var(--c-bg); color: var(--c-text); font-family: 'Inter', sans-serif; }
  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
  .sr-only { position: absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); border:0; }
  .ad-banner-bottom { margin: 4rem auto 6rem; }
</style>

<style>
  /* HERO PREMIUM */
  .hero-home {
    background: radial-gradient(circle at 80% -20%, #1e293b, #020617 80%);
    color: #fff;
    padding: 6rem 0 7rem;
    position: relative;
    overflow: hidden;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .hero-content {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.4rem 1.2rem;
    border-radius: var(--r-pill);
    font-size: 0.85rem; font-weight: 600; color: #93c5fd;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }
  .hero-home h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900; line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.03em;
  }
  .accent-text { 
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .subtitle {
    font-size: clamp(1.1rem, 4vw, 1.3rem); color: #94a3b8; max-width: 650px;
    margin: 0 auto 3.5rem; line-height: 1.6;
  }

  /* SEARCH BAR */
  .search-container { max-width: 680px; width: 100%; margin: 0 auto 3rem; position: relative; }
  .glass-panel {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    border-radius: var(--r-pill);
    transition: all var(--transition);
  }
  .search-input-wrapper { display: flex; align-items: center; padding: 0.85rem 1.5rem; gap: 1rem; }
  .search-input-wrapper:focus-within {
    background: #ffffff;
    border-color: #fff; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.3);
  }
  .search-input-wrapper:focus-within .search-icon { color: var(--c-accent); opacity: 1; }
  .search-input-wrapper:focus-within #main-search { color: var(--c-primary); }
  .search-input-wrapper:focus-within .search-shortcut { display: none; }
  
  .search-icon { width: 22px; height: 22px; color: #fff; opacity: 0.6; transition: all var(--transition); }
  #main-search {
    border: none; outline: none; background: transparent; width: 100%;
    font-size: 1.25rem; font-weight: 500; color: #fff; padding: 0.5rem 0;
  }
  #main-search::placeholder { color: rgba(255, 255, 255, 0.5); }
  .search-shortcut {
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.15); border-radius: 6px;
    padding: 0.3rem 0.6rem; font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.8);
    letter-spacing: 0.05em;
  }

  /* DROPDOWN */
  .search-results {
    position: absolute; top: calc(100% + 1rem); left: 0; right: 0;
    max-height: 400px; overflow-y: auto; z-index: 100; text-align: left;
  }
  .search-results.hidden { display: none; opacity: 0; pointer-events: none; }
  .glass-panel-dropdown {
    background: #ffffff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-base);
    box-shadow: var(--sh-glass);
    animation: dropIn 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes dropIn { from { opacity: 0; transform: translateY(-10px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  
  .search-item {
    display: flex !important; justify-content: space-between; align-items: center !important; 
    padding: 1.2rem 1.75rem !important; border-bottom: 1px solid var(--c-border-light) !important;
    text-decoration: none !important; color: var(--c-text) !important;
    transition: all var(--transition) !important;
  }
  .search-item:last-child { border-bottom: none !important; }
  .search-item-info { display: flex; align-items: center; gap: 1.2rem; }
  .search-item:hover { background: #f8fafc !important; }
  .search-item:hover .search-arrow { transform: translateX(5px); color: var(--c-accent); opacity: 1; }
  .brand-tag {
    font-size: 0.75rem; font-weight: 700; color: var(--c-accent-hover); 
    background: #eff6ff; padding: 0.3rem 0.8rem; border-radius: var(--r-pill); 
    text-transform: uppercase; letter-spacing: 0.05em; min-width: 90px; text-align: center;
  }
  .model-name { font-weight: 700; color: var(--c-primary); font-size: 1.1rem; }
  .search-arrow { opacity: 0; transition: all var(--transition); color: var(--c-text-muted); font-weight: 700; }
  .no-results { padding: 2rem; text-align: center; color: var(--c-text-muted); font-weight: 500; }

  /* STATS */
  .stats-row {
    display: flex; align-items: center; gap: 1.5rem; justify-content: center;
    color: #94a3b8; font-size: 0.95rem; font-weight: 500;
  }
  .stat-item strong { color: #fff; font-weight: 800; font-size: 1.1rem; margin-right: 0.25rem; }
  .stat-divider { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,0.2); }

  /* BRANDS SECTION - SQUARE GRID */
  .brands-section { margin-top: 4rem; margin-bottom: 2rem; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-header h2 { font-size: clamp(2rem, 5vw, 2.75rem); font-weight: 900; margin-bottom: 1rem; color: var(--c-primary); letter-spacing: -0.02em; }
  .section-header p { color: var(--c-text-muted); font-size: 1.15rem; max-width: 600px; margin: 0 auto; }

  /* Square Grid Layout */
  .premium-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem;
  }
  
  .square-card {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 2.5rem 1.5rem; background: var(--c-card); border-radius: var(--r-base);
    border: 1px solid var(--c-border); text-align: center; gap: 1.25rem;
    text-decoration: none; box-shadow: var(--sh-card); position: relative; overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
  }
  
  .brand-logo-circle {
    width: 65px; height: 65px; border-radius: 16px; background: var(--c-bg);
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--c-border-light); z-index: 2; transition: transform 0.3s;
  }
  .brand-logo-circle img { width: 45px; height: 45px; object-fit: contain; }
  .brand-letter-fallback { font-size: 2rem; font-weight: 900; color: var(--c-accent); }
  
  .brand-name { font-weight: 800; color: var(--c-primary); font-size: 1.15rem; z-index: 2; letter-spacing: -0.01em; }
  
  .card-hover-fx {
    position: absolute; inset: 0; opacity: 0; z-index: 1; pointer-events: none; transition: opacity 0.3s;
    background: radial-gradient(circle at 50% 120%, rgba(59,130,246,0.1) 0%, transparent 70%);
  }

  .square-card:hover {
    transform: translateY(-6px); border-color: #bfdbfe;
    box-shadow: var(--sh-card-hover); background: #ffffff;
  }
  .square-card:hover .brand-logo-circle { transform: scale(1.08); background: #eff6ff; border-color: #bfdbfe; }
  .square-card:hover .card-hover-fx { opacity: 1; }

  @media (max-width: 768px) {
    .premium-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1rem; }
    .square-card { padding: 1.5rem 1rem; gap: 1rem; }
    .brand-logo-circle { width: 55px; height: 55px; }
    .brand-logo-circle img { width: 35px; height: 35px; }
    .search-input-wrapper { padding: 0.6rem 1rem; }
    #main-search { font-size: 1.05rem; }
    .search-shortcut { display: none; }
    .hero-home { padding: 4rem 0; }
    .stats-row { flex-direction: column; gap: 0.75rem; }
    .stat-divider { display: none; }
    .search-item-info { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
  }
</style>
