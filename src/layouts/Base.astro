---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; color: #1a1a1a; background: #f8f8f8; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
    header { background: #1a1a2e; color: white; padding: 1rem 0; }
    header a { color: white; text-decoration: none; font-weight: bold; font-size: 1.3rem; }
    nav { display: flex; gap: 1.5rem; margin-top: 0.5rem; }
    nav a { color: #ccc; text-decoration: none; font-size: 0.9rem; }
    nav a:hover { color: white; }
    main { padding: 2rem 0; }
    footer { background: #1a1a2e; color: #aaa; padding: 2rem 0; text-align: center; font-size: 0.85rem; margin-top: 4rem; }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <a href="/">🔧 Distribution Auto</a>
      <nav>
        <a href="/distribution">Toutes les marques</a>
        <a href="/guides">Guides</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <slot />
  </main>
  <footer>
    <div class="container">
      © 2026 Distribution Auto — Chaîne ou courroie pour tous les véhicules
    </div>
  </footer>
</body>
</html>
